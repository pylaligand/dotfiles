[alias]
    can = "commit --amend --no-edit"
    cmp = "!git checkout main && git pull --rebase"
    lo = "log --oneline --decorate"
    nb = "!git checkout -b $1 origin/main #"
    po = "push origin HEAD"
    pof = "push --force origin HEAD"
    st = "show HEAD --stat --format=''"
    stu = "diff HEAD --stat"
    up = "branch --set-upstream-to=origin/main"

[core]
    excludesFile = ~/.my.gitignore

[rebase]
    autoStash = true
